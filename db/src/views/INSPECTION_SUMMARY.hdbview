VIEW "INSPECTION_SUMMARY" AS
    SELECT
        "FORKLIFT_ID",
        COUNT("INSPECTION_ID")  AS "TOTAL_INSPECTIONS",
        SUM(CASE WHEN "STATUS" = 'READY' THEN 1 ELSE 0 END) AS "READY_COUNT",
        SUM(CASE WHEN "STATUS" = 'NOT_READY' THEN 1 ELSE 0 END) AS "NOT_READY_COUNT",
        MAX("INSPECTION_DATE")  AS "LAST_INSPECTION",
        MAX("ODOMETER")         AS "LAST_ODOMETER"
    FROM "INSPECTIONS"
    GROUP BY "FORKLIFT_ID";
